# SatsRemit Configuration
# Copy to .env and fill in actual values

# ========== DATABASE ==========
DATABASE_URL=postgresql://satsremit:password@localhost:5432/satsremit
DATABASE_ECHO=false

# ========== REDIS ==========
REDIS_URL=redis://localhost:6379/0

# ========== LND (Lightning Network Daemon) ==========
LND_REST_URL=https://127.0.0.1:8080
LND_MACAROON_PATH=/data/lnd/data/chain/bitcoin/testnet/admin.macaroon
LND_CERT_PATH=/data/lnd/tls.cert
LND_HOLD_INVOICE_EXPIRY_MINUTES=5760
LND_INVOICE_TIMEOUT_HOURS=6.5

# ========== BITCOIN ==========
BITCOIN_NETWORK=testnet  # testnet or mainnet
BITCOIN_RPC_URL=http://localhost:18332
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=password

# ========== WHATSAPP BUSINESS API ==========
# https://developers.facebook.com/docs/whatsapp/cloud-api/
# Get credentials from: https://developers.facebook.com/
WHATSAPP_BUSINESS_ACCOUNT_ID=your_account_id
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your_access_token
# WhatsApp: Free to opted-in users (no per-message cost)
# Recommended: Use shortcode for brand recognition

# ========== RATE FEEDS ==========
RATE_SOURCE=coingecko  # coingecko, kraken, or binance
RATE_CACHE_MINUTES=5

# ========== PLATFORM ==========
PLATFORM_FEE_PERCENT=0.5  # 0.5% platform fee
AGENT_COMMISSION_PERCENT=0.5  # 0.5% agent commission
MIN_TRANSFER_ZAR=100
MAX_TRANSFER_ZAR=500
PIN_EXPIRY_MINUTES=5

# ========== SECURITY ==========
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
Rate_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_MINUTES=60

# ========== PAYMENT METHODS ==========
ALLOWED_WITHDRAWAL_METHODS=bank_transfer,physical_cash,mobile_money

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# ========== ENVIRONMENT ==========
DEBUG=false
ENVIRONMENT=development  # development, staging, production

# ========== WEBHOOK SECRET ==========
WEBHOOK_SECRET=your-webhook-secret

# ========== AGENT SETTINGS ==========
AGENT_LOCATION_CODE=ZWE_HRR  # Zimbabwe Harare example
VERIFICATION_TIMEOUT_MINUTES=60
AUTO_REFUND_AFTER_HOURS=1
