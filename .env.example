# SatsRemit Configuration
# ============================================================
# Copy this file to .env and fill in EVERY value marked REQUIRED.
#
# DO NOT copy placeholder values as-is — the server will refuse
# to start if JWT_SECRET_KEY or WEBHOOK_SECRET are still set to
# their example values.  Generate real secrets with the commands
# shown in each section below.
# ============================================================

# ========== DATABASE ==========
# REQUIRED — PostgreSQL connection string
DATABASE_URL=postgresql://satsremit:CHANGE_ME_DB_PASSWORD@localhost:5432/satsremit
DATABASE_ECHO=false

# ========== REDIS ==========
# REQUIRED
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/1

# ========== LND (Lightning Network Daemon) ==========
# REQUIRED
LND_REST_URL=https://127.0.0.1:8080
LND_MACAROON_PATH=/data/lnd/chain/bitcoin/testnet4/admin.macaroon
LND_CERT_PATH=/data/lnd/tls.cert
LND_HOLD_INVOICE_EXPIRY_MINUTES=5760
LND_INVOICE_TIMEOUT_HOURS=6.5

# ========== BITCOIN ==========
BITCOIN_NETWORK=testnet4
BITCOIN_RPC_URL=http://localhost:28332
BITCOIN_RPC_USER=bitcoin
# REQUIRED — change from the default
BITCOIN_RPC_PASSWORD=CHANGE_ME_RPC_PASSWORD

# ========== WHATSAPP BUSINESS API ==========
# https://developers.facebook.com/docs/whatsapp/cloud-api/
# REQUIRED for notifications to work
WHATSAPP_BUSINESS_ACCOUNT_ID=REPLACE_WITH_YOUR_ACCOUNT_ID
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=REPLACE_WITH_YOUR_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ACCESS_TOKEN=REPLACE_WITH_YOUR_ACCESS_TOKEN

# ========== RATE FEEDS ==========
RATE_SOURCE=coingecko
RATE_CACHE_MINUTES=5

# ========== PLATFORM ==========
PLATFORM_FEE_PERCENT=0.5
AGENT_COMMISSION_PERCENT=0.5
MIN_TRANSFER_ZAR=100
MAX_TRANSFER_ZAR=500
PIN_EXPIRY_MINUTES=5

# ========== SECURITY ==========
#
# REQUIRED — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# The server will REFUSE TO START if this is left as a placeholder
# or is shorter than 32 characters.
JWT_SECRET_KEY=GENERATE_ME_run_python_-c_import_secrets_print_secrets.token_hex_32

JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_MINUTES=60

# REQUIRED — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Used for HMAC-SHA256 verification of LND webhook callbacks.
# A guessable value allows an attacker to forge invoice-settled events.
WEBHOOK_SECRET=GENERATE_ME_run_python_-c_import_secrets_print_secrets.token_hex_32

# REQUIRED in production — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Used to encrypt LND preimages at rest.  In development this field can
# be omitted (a key is derived from JWT_SECRET_KEY), but in production
# it must be set independently so JWT secret rotation does not invalidate
# stored preimage ciphertexts.
PREIMAGE_ENCRYPTION_KEY=GENERATE_ME_run_python_-c_from_cryptography.fernet_import_Fernet_print_Fernet.generate_key().decode()

# ========== PAYMENT METHODS ==========
ALLOWED_WITHDRAWAL_METHODS=bank_transfer,physical_cash,mobile_money

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========== ENVIRONMENT ==========
# Set to "production" on the live server. DEBUG must be false in production.
DEBUG=false
ENVIRONMENT=development

# ========== AGENT SETTINGS ==========
AGENT_LOCATION_CODE=ZWE_HRR
VERIFICATION_TIMEOUT_MINUTES=60
AUTO_REFUND_AFTER_HOURS=1
